{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "analysis": {
      "description": "Analyze code for potential issues, vulnerabilities and improvements",
      "prompt": "{file:./prompts/AGENTS.md}",
      "mode": "primary",
      "temperature": 0.1,
      "tools": {
        "plural*": true,
      },
      "permission": {
        "bash": {
          "ls": "allow",
          "cd": "allow",
          "pwd": "allow",
          "git status": "allow",
          "git diff": "allow",
          "head": "allow",
          "tail": "allow",
          "cat": "allow",
          "grep": "allow",
          "find": "allow",
          "*": "deny"
        },
        "edit": "deny",
        "webfetch": "allow"
      }
    },
    "autonomous": {
      "description": "Autonomous agent for making code changes and creating pull requests",
      "prompt": "{file:./prompts/AGENTS.md}",
      "mode": "primary",
      "temperature": 0.3,
      "tools": {
        "plural*": true,
        "write": false,
        "todowrite": false,
        "edit": false
      },
      "permission": {
        "bash": "allow",
        "edit": "allow",
        "webfetch": "allow"
      }
    }
  },
  "mcp": {
    "plural": {
      "type": "local",
      "command": ["mcpserver"],
      "enabled": true,
      "environment": {
        "PLRL_CONSOLE_TOKEN": "{{ .ConsoleToken }}",
        "PLRL_CONSOLE_URL": "{{ .ConsoleURL }}",
        "PLRL_AGENT_RUN_ID": "{{ .AgentRunID }}",
        {{ if eq .Mode "WRITE" }}
        "PLRL_EXCLUDE_TOOLS": "updateAgentRunAnalysis"
        {{ else }}
        "PLRL_EXCLUDE_TOOLS": "createBranch,agentPullRequest,fetchAgentRunTodos,updateAgentRunTodos"
        {{ end }}
      }
    }
  },
  "username": "plural",
  "provider": {
    "plural": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "plural",
      "options": {
        "baseURL": "{{ .ConsoleURL }}/ext/ai/v1",
        "apiKey": "{{ .ConsoleToken }}"
      },
      "models": {
        "openai/{{ .Model }}": {
          "name": "{{ .Model }}"
        }
      }
    }{{ if ne .Provider "plural" }},
    "{{ .Provider }}": {
      "name": "{{ .Provider }}",
      "options": {
        "baseURL": "{{ .Endpoint }}",
        "apiKey": "{{ .Token }}"
      },
      "models": {
        "{{ .Model }}": {
          "name": "{{ .Model }}"
        }
      }
    }
    {{ end }}
  }
}